# PostgreSQL connection string used by Prisma
DATABASE_URL=postgresql://user:password@localhost:5432/vael?schema=public

# Secret used to sign admin session JWTs (use a long random string)
AUTH_SECRET=

# Resend API key for the contact form
RESEND_API_KEY=

# Where contact form submissions are delivered
CONTACT_TO=

# Verified sender address for outgoing mail
CONTACT_FROM=

# Admin credentials for the seed script only. These are read by
# prisma/seed.ts to create the initial admin user and are not used at runtime.
ADMIN_EMAIL=
ADMIN_PASSWORD=

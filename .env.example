# PostgreSQL connection string used by Prisma
DATABASE_URL=postgresql://user:password@localhost:5432/vael?schema=public

# Secret used to sign admin session JWTs (use a long random string)
AUTH_SECRET=

# Resend API key for the contact form
RESEND_API_KEY=

# Where contact form submissions are delivered
CONTACT_TO=

# Verified sender address for outgoing mail
CONTACT_FROM=

# Admin credentials for the seed step only. On container start the seed creates
# this user if no account with ADMIN_EMAIL exists yet. They only take effect on
# the first boot: once the user exists, the seed never changes its password, and
# these vars are ignored. Not used anywhere else at runtime.
ADMIN_EMAIL=
ADMIN_PASSWORD=
